{
  "name": "payseal-desktop",
  "version": "1.0.0",
  "description": "PaySeal Desktop — Seal payslips from your desktop",
  "author": "Hector Bekaert <hello@payseal.io>",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mw"
  },
  "build": {
    "appId": "io.payseal.desktop",
    "productName": "PaySeal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PaySeal"
    },
  "mac": {
  "target": [
    {
      "target": "dmg",
      "arch": ["x64", "arm64"]
    }
  ],
  "category": "public.app-category.business",
  "identity": null
},
"dmg": {
  "title": "PaySeal ${version}",
  "contents": [
    { "x": 130, "y": 220, "type": "file" },
    { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
  ]
}
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}